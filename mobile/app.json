{
  "expo": {
    "name": "Build.me",
    "slug": "buildme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.buildme.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Build.me needs camera access to take photos of your job.",
        "NSPhotoLibraryUsageDescription": "Build.me needs photo library access to attach photos to your enquiry.",
        "NSPhotoLibraryAddUsageDescription": "Build.me needs permission to save photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.buildme.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Build.me needs photo library access to attach photos to your enquiry.",
          "cameraPermission": "Build.me needs camera access to take photos of your job."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#F59E0B",
          "defaultChannel": "default"
        }
      ]
    ],
    "scheme": "buildme"
  }
}
