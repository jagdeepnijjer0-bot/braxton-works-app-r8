# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
ADMIN_EMAIL=admin@braxtonworks.co.uk

# ─── Google Sheets ───────────────────────────────────────────
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=braxton-sheets@your-project.iam.gserviceaccount.com
# Paste the private key exactly as it appears in the JSON key file (including \n characters)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
